# Copy this file to ".env" in the same folder (Medor.Api) or repo root.
# The real ".env" file is gitignored — do not commit secrets.
#
# ASP.NET Core reads nested configuration via environment variables using "__":
#   ConnectionStrings__DefaultConnection

ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=MedorDb;User Id=sa;Password=REPLACE_WITH_STRONG_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true;Encrypt=True
