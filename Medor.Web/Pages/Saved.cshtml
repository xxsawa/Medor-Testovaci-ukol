@page "/saved"
@model SavedModel
@{
    ViewData["Title"] = "Uložená data";
}

<div class="row g-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h4 mb-3">Uložené záznamy</h2>
                <p class="text-muted small">Filtrování a řazení podle sloupců. Poznámka musí být vyplněna před uložením změn.</p>
                <div class="alert alert-warning py-2 px-3 small mb-2" id="saved-unsaved" role="status" style="display:none;">
                    Máte neuložené změny v poznámkách. Uložte je tlačítkem Uložit změny.
                </div>
                <div class="mb-2">
                    <button type="button" class="btn btn-outline-danger btn-sm" id="btn-delete">Smazat vybrané záznamy</button>
                    <button type="button" class="btn btn-primary btn-sm" id="btn-save-notes">Uložit změny</button>
                    <span class="text-danger ms-2" id="saved-error" style="display:none;"></span>
                    <span class="text-success ms-2" id="saved-ok" style="display:none;"></span>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered w-100" id="saved-table" style="width:100%">
                        <thead>
                            <tr>
                                <th><input type="checkbox" id="chk-all" title="Vybrat vše" /></th>
                                <th>Id</th>
                                <th>BTC/EUR</th>
                                <th>EUR/CZK</th>
                                <th>BTC/CZK</th>
                                <th>ČNB platnost</th>
                                <th>Čas (UTC)</th>
                                <th>Poznámka</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="h5">Graf uložených cen (BTC/CZK)</h3>
                <canvas id="saved-chart" height="120"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.8/css/dataTables.dataTables.min.css" />
    <script src="https://cdn.datatables.net/2.1.8/js/dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.6/dist/chart.umd.min.js"></script>
    <script type="module" src="~/js/medor/saved-page.js" asp-append-version="true"></script>
}
